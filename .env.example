# Copy to .env (next to docker-compose.yml). Every variable is optional —
# the stack runs with the defaults below.

# Host port nginx listens on (http://localhost:8080).
APP_PORT=8080

POSTGRES_PASSWORD=postgres

# Set a long random string in production.
JWT_SECRET=dev-only-secret-change-me-in-production-0123456789

# Optional: Claude-powered chat intake on the backend (/intake/message).
ANTHROPIC_API_KEY=

# Optional: frontend AI features (Ingestion Hub, ToxCheck, nutrition, search).
LOVABLE_API_KEY=

# Clinic EHR import (POST /api/external/ehr).
# CLINIC_API_KEY is the shared secret clinics send as the X-API-Key header —
# set a long random string and share it only with integrated clinics.
CLINIC_API_KEY=dev-clinic-key-change-me

# Gemini (lab normalization + voice intake). Auth, preferred first:
#  1) gcloud ADC / Vertex AI: run `gcloud auth application-default login`;
#     compose mounts ~/.config/gcloud/application_default_credentials.json
#     into the backend. If the file lives elsewhere (e.g. compose runs on
#     Windows but gcloud lives in WSL), point GCLOUD_ADC_FILE at it:
#     GCLOUD_ADC_FILE=\\wsl.localhost\Ubuntu\home\<user>\.config\gcloud\application_default_credentials.json
#     Set GOOGLE_CLOUD_PROJECT if the ADC file carries no quota project.
#  2) GEMINI_API_KEY: Gemini Developer API key.
# With neither, clinic EHR import (Gemini is required for it) and voice
# intake are unavailable.
# GCLOUD_ADC_FILE=
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=global
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.5-flash
